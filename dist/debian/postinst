#!/bin/bash
set -e

case "$1" in
    configure)
        TARGET_UID="${SUDO_UID:-$(id -u)}"
        SOCK="/run/user/${TARGET_UID}/scribe/server.sock"
        XDG_DIR="/run/user/${TARGET_UID}"

        # Check for a running server process, not just a stale socket file
        SERVER_RUNNING=0
        if [ -S "$SOCK" ] && pgrep -u "$TARGET_UID" -x scribe-server >/dev/null 2>&1; then
            SERVER_RUNNING=1
        fi

        if [ "$SERVER_RUNNING" = "1" ]; then
            # Upgrade: server is running — launch hot-reload in background.
            # The --upgrade process takes over from the old server (receives
            # PTY fds, starts serving). We run it in the background because
            # it continues running as the new server after handoff.
            echo ""
            echo "Scribe server is running. Starting hot-reload..."

            UPGRADE_BIN="/usr/bin/scribe-server"
            # Use mktemp instead of predictable /tmp paths to prevent
            # TOCTOU symlink attacks from other local users.
            UPGRADE_LOG=$(mktemp /run/user/"${TARGET_UID}"/scribe/upgrade-log.XXXXXX) || \
                UPGRADE_LOG=$(mktemp)
            # mktemp runs as root; chown so the user subprocess can write.
            chown "${TARGET_UID}" "${UPGRADE_LOG}" 2>/dev/null || true

            # Launch the upgrade server detached from sudo.
            #
            # Plain `sudo -u user server &` makes sudo wait for the
            # long-lived server child — it never exits, leaving zombie
            # sudo processes after every install.  Using `sh -c '... &'`
            # backgrounds the server *inside* the sh, so sh exits
            # immediately, sudo exits, and the server is reparented to
            # init.  The PID is captured via stdout.
            if [ -n "$SUDO_UID" ]; then
                UPGRADE_PID=$(sudo -u "#${SUDO_UID}" sh -c '
                    "$1" --upgrade >"$2" 2>&1 &
                    echo $!
                ' _ "${UPGRADE_BIN}" "${UPGRADE_LOG}")
            else
                "${UPGRADE_BIN}" --upgrade >"${UPGRADE_LOG}" 2>&1 &
                UPGRADE_PID=$!
            fi

            # Wait briefly for the new server to be fully ready. We check
            # for "IPC server listening" (emitted after socket bind) rather
            # than "session restoration complete" to ensure the new server is
            # accepting connections before we kill the old one.
            UPGRADE_OK=0
            for i in 1 2 3 4 5; do
                sleep 1
                if grep -q "IPC server listening" "${UPGRADE_LOG}" 2>/dev/null; then
                    UPGRADE_OK=1
                    break
                fi
                # Check if the upgrade process died
                if ! kill -0 "$UPGRADE_PID" 2>/dev/null; then
                    break
                fi
            done

            if [ "$UPGRADE_OK" = "1" ]; then
                echo "  ✓ Scribe server hot-reloaded successfully."
                echo "    All terminal sessions have been preserved."

                # The old server exits on its own after handoff (clean exit
                # code 0). With Restart=on-failure in the service file,
                # systemd will not auto-restart it.  The singleton flock
                # in acquire_server_socket prevents duplicate servers.
                #
                # We intentionally do NOT `systemctl stop` or kill server
                # processes here:
                #  - `systemctl stop` uses KillMode=control-group by default,
                #    which sends SIGTERM to ALL processes in the cgroup —
                #    including the user's shell sessions from the PTY.
                #    This kills the very sessions we're trying to preserve
                #    and causes a 90-second hang waiting for bash to exit.
                #  - Killing via `kill` would cause systemd to see a
                #    signal exit, triggering Restart=on-failure.

                # Relaunch clients if any were running before the upgrade
                # (recorded by preinst before the old binary was replaced)
                STATE_FILE="/run/user/${TARGET_UID}/scribe/upgrade-state"
                PREV_CLIENTS=$(cat "${STATE_FILE}" 2>/dev/null || echo "0")
                rm -f "${STATE_FILE}" 2>/dev/null || true

                if [ "$PREV_CLIENTS" -gt 0 ] 2>/dev/null; then
                    echo "  Relaunching client..."
                    if [ -n "$SUDO_UID" ]; then
                        # Forward display and session environment so the GPU
                        # client can open a window under the user's session.
                        # Each variable is passed as a separately quoted argument
                        # to avoid word-splitting injection via $DISPLAY values.
                        sudo -u "#${SUDO_UID}" \
                            ${DISPLAY:+"DISPLAY=$DISPLAY"} \
                            ${WAYLAND_DISPLAY:+"WAYLAND_DISPLAY=$WAYLAND_DISPLAY"} \
                            XDG_RUNTIME_DIR="$XDG_DIR" \
                            DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_DIR}/bus" \
                            nohup /usr/bin/scribe-client >/dev/null 2>&1 &
                    else
                        nohup /usr/bin/scribe-client >/dev/null 2>&1 &
                    fi
                fi
            else
                # Kill the stuck upgrade process
                kill "$UPGRADE_PID" 2>/dev/null || true

                echo ""
                echo "  ⚠  Hot-reload failed. A cold restart is needed to"
                echo "     complete the upgrade."
                echo ""
                echo "     This will CLOSE all open terminal sessions."
                echo ""

                if [ -f "${UPGRADE_LOG}" ]; then
                    echo "  Error details:"
                    tail -3 "${UPGRADE_LOG}" 2>/dev/null | sed 's/^/    /'
                    echo ""
                fi

                # Prompt for cold restart. Read from /dev/tty since stdin
                # may be piped through apt/dpkg.
                RESTART_CONFIRMED=0
                if [ -e /dev/tty ]; then
                    printf "  Restart now? (this will kill all running terminals) [y/N] "
                    read -r REPLY < /dev/tty 2>/dev/null || REPLY=""
                    case "$REPLY" in
                        y|Y|yes|YES) RESTART_CONFIRMED=1 ;;
                    esac
                fi

                if [ "$RESTART_CONFIRMED" = "1" ]; then
                    if [ -n "$SUDO_UID" ]; then
                        sudo -u "#${SUDO_UID}" \
                            XDG_RUNTIME_DIR="$XDG_DIR" \
                            DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_DIR}/bus" \
                            systemctl --user restart scribe-server 2>/dev/null
                    else
                        systemctl --user restart scribe-server 2>/dev/null
                    fi
                    echo ""
                    echo "  ✓ Scribe server restarted with new version."
                else
                    echo ""
                    echo "  Skipped. To complete the upgrade later, run:"
                    echo ""
                    echo "    systemctl --user restart scribe-server"
                fi
            fi
            # Clean up all upgrade logs (current + stale from previous installs).
            rm -f /run/user/"${TARGET_UID}"/scribe/upgrade-log.* 2>/dev/null || true
            echo ""
        else
            # Fresh install: clean up any stale socket and start the service
            rm -f "$SOCK" 2>/dev/null || true

            STARTED=0

            if [ -n "$SUDO_UID" ] && [ -d "$XDG_DIR" ]; then
                sudo -u "#${SUDO_UID}" \
                    XDG_RUNTIME_DIR="$XDG_DIR" \
                    DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_DIR}/bus" \
                    systemctl --user enable scribe-server 2>/dev/null && \
                sudo -u "#${SUDO_UID}" \
                    XDG_RUNTIME_DIR="$XDG_DIR" \
                    DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_DIR}/bus" \
                    systemctl --user start scribe-server 2>/dev/null && \
                STARTED=1
            elif [ -z "$SUDO_UID" ]; then
                systemctl --user enable scribe-server 2>/dev/null && \
                systemctl --user start scribe-server 2>/dev/null && \
                STARTED=1
            fi

            if [ "$STARTED" = "1" ]; then
                echo "  ✓ Scribe server enabled and started."
                echo "    Run 'scribe-client' to open a terminal."
            else
                echo ""
                echo "  Scribe installed successfully."
                echo ""
                echo "  To start the server, run:"
                echo "    systemctl --user enable --now scribe-server"
                echo ""
                echo "  Then launch the terminal:"
                echo "    scribe-client"
            fi
            echo ""
        fi

        # ── Claude Code hook integration (both fresh and upgrade) ───────
        SETUP_SCRIPT="/usr/share/scribe/setup-claude-hooks.sh"
        if [ -x "$SETUP_SCRIPT" ]; then
            TARGET_HOME=$(eval echo "~$(id -un "$TARGET_UID")" 2>/dev/null) || true
            CLAUDE_DIR="${TARGET_HOME}/.claude"

            if [ -d "$CLAUDE_DIR" ]; then
                echo "  Setting up Claude Code AI indicator hooks..."
                if [ -n "$SUDO_UID" ]; then
                    sudo -u "#${SUDO_UID}" \
                        HOME="$TARGET_HOME" \
                        "$SETUP_SCRIPT" --hook-source /usr/share/scribe 2>&1 | sed 's/^/  /'
                else
                    "$SETUP_SCRIPT" --hook-source /usr/share/scribe 2>&1 | sed 's/^/  /'
                fi
            fi
        fi
        ;;
esac

exit 0
