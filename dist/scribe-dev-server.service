[Unit]
Description=Scribe Dev Terminal PTY Server
Documentation=https://github.com/scribe-terminal/scribe

[Service]
Type=simple
ExecStart=/usr/bin/scribe-dev-server
Restart=on-failure
RestartSec=1
# Only send stop signals to the main server process, not to PTY child
# processes (user shells) that live in the same cgroup. The default
# KillMode=control-group would kill all shell sessions on `systemctl stop`.
KillMode=process

[Install]
WantedBy=default.target
