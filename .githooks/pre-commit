#!/usr/bin/env bash
# Fast pre-commit checks — runs on every commit
# Full checks (cargo deny, cargo test) run via pre-commit framework or CI
set -euo pipefail

echo "==> cargo fmt check"
cargo fmt --all -- --check

echo "==> cargo clippy"
cargo clippy --workspace --all-targets --all-features -- -D warnings

echo "==> cargo test"
cargo test --workspace --quiet

echo "==> All pre-commit checks passed"
